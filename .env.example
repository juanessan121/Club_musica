# =============================================================================
# VARIABLES DE ENTORNO - Sistema Club de Música
# =============================================================================
# Copie este archivo a .env y ajuste los valores para su entorno
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS - PostgreSQL
# -----------------------------------------------------------------------------
DB_USER=clubmusica
DB_PASSWORD=clubmusica_secret_2026
DB_NAME=club_musica
DB_PORT=5432

# -----------------------------------------------------------------------------
# API - Node.js
# -----------------------------------------------------------------------------
NODE_ENV=production
API_PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# JWT Authentication
JWT_SECRET=cambiar_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# FRONTEND - React
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_WS_URL=ws://localhost:3000/ws
WEB_PORT=3001

# -----------------------------------------------------------------------------
# MINIO - Object Storage
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret_cambiar_en_produccion
MINIO_BUCKET=partituras
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# REDIS - Cache
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis_secret_2026
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# EMAIL - SMTP Configuration
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clubmusica.cl

# -----------------------------------------------------------------------------
# NGINX - Reverse Proxy
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# PGADMIN - Database Admin (Desarrollo)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@clubmusica.cl
PGADMIN_PASSWORD=pgadmin_secret_2026
PGADMIN_PORT=8080

# -----------------------------------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
LOG_LEVEL=info
