# =============================================================================
# VARIABLES DE ENTORNO — Sistema Club de Música (Flask + MariaDB + React)
# =============================================================================
# Copia este archivo a .env y reemplaza los valores marcados como CAMBIAR_*.
#
# Forma automática (recomendada): ejecuta  bash scripts/setup.sh
# Genera .env con secretos aleatorios fuertes y levanta todo el stack.
#
# Forma manual: genera valores aleatorios con
#   openssl rand -base64 24   # para contraseñas de BD
#   openssl rand -hex 32      # para JWT_SECRET (mínimo 32 caracteres)
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS — MariaDB
# -----------------------------------------------------------------------------
DB_ROOT_PASSWORD=CAMBIAR_contraseña_root_segura
DB_USER=clubmusica
DB_PASSWORD=CAMBIAR_contraseña_segura
DB_NAME=club_musica

# -----------------------------------------------------------------------------
# API — Flask
# -----------------------------------------------------------------------------
FLASK_ENV=production
JWT_SECRET=CAMBIAR_minimo_32_caracteres_aleatorios

# CORS (orígenes permitidos, separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8088,http://127.0.0.1:3001,http://127.0.0.1:8088

# -----------------------------------------------------------------------------
# FRONTEND — React
# -----------------------------------------------------------------------------
# El frontend (puerto 3001, servidor de desarrollo) llama directamente a la API
# expuesta en el puerto 5000 — necesario porque el dev server de React no puede
# alcanzar el contenedor de la API por red interna Docker.
REACT_APP_API_URL=http://localhost:5000/api
WEB_PORT=3001

# -----------------------------------------------------------------------------
# EMAIL — SMTP (deja SMTP_USER/SMTP_PASS vacíos para simular envíos en consola)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clubmusica.pucesa.edu.ec

# -----------------------------------------------------------------------------
# NGINX — Reverse Proxy
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=8088
NGINX_HTTPS_PORT=8443
